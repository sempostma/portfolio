    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@mdx-js/rollup": "^3.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/d3": "^7.4.3",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
