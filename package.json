{
  "name": "sem-postma-portfolio",
  "version": "3.0.0",
  "description": "Personal portfolio website of Sem Postma — Full-Stack Developer & Software Engineer. Built with React, TypeScript, Vite, and Tailwind CSS.",
  "type": "module",
  "private": true,
  "homepage": "https://sem-postma.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sempostma/portfolio.git"
  },
  "bugs": {
    "url": "https://github.com/sempostma/portfolio/issues"
  },
  "author": {
    "name": "Sem Postma",
    "email": "sem@postma.com",
    "url": "https://sem-postma.com"
  },
  "license": "MIT",
  "keywords": [
    "portfolio",
    "personal-website",
    "react",
    "typescript",
    "vite",
    "tailwindcss",
    "mdx",
    "d3",
    "developer-portfolio",
    "sem-postma"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
